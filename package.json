{
  "name": "the-goodies-typescript",
  "version": "0.1.0",
  "description": "TypeScript client for The Goodies smart home knowledge graph",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
